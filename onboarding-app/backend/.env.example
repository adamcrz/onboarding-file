PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/complianceos

# JWT — change this to a long random string in production
JWT_SECRET=change-this-to-a-strong-random-secret

# ─── Email ────────────────────────────────────────────────────────────────────
# Leave all EMAIL_* blank to use Ethereal (fake SMTP, preview in console).
# For Gmail: set EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587,
#            EMAIL_USER=you@gmail.com, EMAIL_PASS=your-app-password
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="ComplianceOS" <noreply@complianceos.com>

# Base URL of the frontend — used to build verify/reset links in emails
# Live Server default: http://127.0.0.1:5500
FRONTEND_URL=http://127.0.0.1:5500
